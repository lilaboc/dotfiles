#!/usr/bin/env python2
import sys
if sys.platform == 'linux2':
    import bsddb3
    import readline
else:
    import bsddb
    bsddb3 = bsddb
import re
import urllib
import socket
import json
import random
import string
import os
import thread
import threading
import cPickle
import tempfile
import bz2
import Queue
try:
    import psyco
    psyco.full()
except:
    pass
socket.setdefaulttimeout(20)
#forvo api key lilaboc:abd50f6338b295db8fb25489d4cec4c0
#forvo api key yunqingh:584836910f0f5440a2ae76d96bde8cb7
forvo_api_key = ['abd50f6338b295db8fb25489d4cec4c0', '584836910f0f5440a2ae76d96bde8cb7']


def playmp3(c):
    for i in c:
        f = tempfile.NamedTemporaryFile(delete=False, suffix='.mp3')
        with f:
            f.write(i)
            f.flush()
            f.close()
            if sys.platform == 'linux2':
                os.system('mpg123 -q ' + '"' + f.name + '"')
            else:
                os.system('cmdmp3.exe ' + '"' + f.name + '"')

def isCaculatable(w):
    symbols = '()+-*/|^&% ' + string.digits
    for i in w:
        if i not in symbols:
            return False
    return True

def isEnglish(w):
    for i in w:
        if i not in string.printable:
            return False
    return True


def sound(w, lock, semaphore):
    dbname = 'pronounciation.db'
    if isEnglish(w):
        db = getdb(dbname, 'r')
        if db.has_key(w):
            with lock:
                playmp3(cPickle.loads(bz2.decompress(db[w])))
        else:
            try:
                random.seed()
                key = random.choice(forvo_api_key)
                url = 'http://apifree.forvo.com/key/' + key + '/format/json/action/word-pronunciations/word/' + urllib.quote(w) + '/language/en'
                a = urllib.urlopen(url).read()
                #print a
                b = json.loads(a)
                if len(b['items']) > 0:
                    url = []
                    url.append(b['items'][0]['pathmp3'])
                    for i in b['items'][1:]:
                        if i['country'] != b['items'][0]['country']:
                            url.append(i['pathmp3'])
                            break
                    sounds = []
                    for i in url:
                        c = urllib.urlopen(i).read()
                        sounds.append(c)
                    db.close()
                    tdb = getdb(dbname, 'w')
                    tdb[w] = bz2.compress(cPickle.dumps(sounds))
                    tdb.sync()
                    tdb.close()
                    with lock:
                        playmp3(sounds)
            except Exception ,exp:
                #print(exp)
                pass
    semaphore.release()

            
def getdb(dbname, mode):
    dbpath = dbname
    if sys.platform == 'linux2':
        dbpath = os.path.expanduser('~/bin/' + dbpath)
    if not os.path.exists(dbpath):
        db = bsddb3.btopen(dbpath, 'w')
        db.close()

        print(dbpath + " doesn't exist, created")
    return bsddb3.btopen(dbpath, mode)
        
def query(w, lock, semaphore):
    try:
        dbname = 'db2.db'
        db = getdb(dbname, 'r')
        if db.has_key(w):
            result = cPickle.loads(bz2.decompress(db[w]))
        else:
            result = {}
            q = Queue.Queue()
            for i in query_methods.keys():
                thread.start_new_thread(query_methods[i],(w, q, i))
            for i in xrange(len(query_methods)):
                r = q.get(True)
                if r[1]:
                    result[r[0]] = r[1]
            if len(result.keys()) > 0:
                db = getdb(dbname, 'w')
                db[w] = bz2.compress(cPickle.dumps(result))
                db.sync()
                db.close()
            else:
                print("not found...")
        if len(result.keys()) > 0:
            with lock:
                print '-' * 45
                print '[' + w + ']'
                for i in result.keys():
                    print('%' + i + "%:")
                    if sys.platform != 'linux2':
                        try:
                            print(result[i].decode('utf-8').encode('cp936'))
                        except:
                            print(result[i])
                    else:
                        print(result[i])
                print '-' * 76 
    except:
        pass
    if None != semaphore:
        semaphore.release()

def query_google(w, q, name):
    r = ''
    if isEnglish(w):
        url = 'http://www.google.com/dictionary/json?callback=dict_api.callbacks.id100&q=' + urllib.quote(w) + '&sl=en&tl=en&restrict=pr%3Cde&client=te'
        while True:
            try:
                js = urllib.urlopen(url).read()
                break
            except:
                continue
        r = re.search('^[^\(]+\((?P<json>.*?),[^,]+,[^,]+\)$', js, re.M|re.I|re.S|re.U).group('json')
        explain = json.loads(re.sub('\\\\x', r'\u00', r))
        result = []
        if explain.has_key('primaries'):
            for i in explain['primaries'][0]['entries']:
                if i['type'] == 'meaning':
                    result.append(unicode(re.sub('<[^>]+?>', ' ', i['terms'][0]['text'])).encode('utf-8'))
        q.put([name, '\n'.join(result)])
    else:
        q.put([name, ''])

def query_baidu(w, q, name):
    url = 'http://dict.baidu.com/s?wd=' + urllib.quote(w)
    while True:
        try:
            js = urllib.urlopen(url).read()
            break
        except:
            continue
    r = re.search('<div class="tab en-simple-means dict-en-simplemeans-english" id="en-simple-means">(?P<meaning>.*?)</div>', js, re.M|re.S|re.I)
    if r:
        r = re.sub('<.*?>', '', r.group('meaning').replace('</p>', '\n'), re.I|re.M|re.S).strip()
        q.put([name, r])
    else:
        q.put([name, ''])
        

#query_methods = {'dictcn': query_dictcn_3g, 'google': query_google}
query_methods = {'google': query_google, 'baidu': query_baidu}

def main():
    slock = thread.allocate_lock()
    qlock = thread.allocate_lock()
    if len(sys.argv) >= 2:
        w = ' '.join(sys.argv[1:])
        query(w, qlock, None)
    else:
        #only 20 lookup can be done simutanously
        #avoid lots of lookup been pasted to console
        semaphore = threading.Semaphore(20) 
        while True:
            try:
                w = raw_input('').strip().lower()
                if w == 'x':
                    break
                if w == '':
                    continue
                else:
                    if isCaculatable(w):
                        try:
                            print(eval(w))
                            continue
                        except:
                            pass
                    semaphore.acquire()
                    thread.start_new_thread(sound ,(w, slock, semaphore))
                    semaphore.acquire()
                    thread.start_new_thread(query, (w, qlock, semaphore))
            except EOFError:
                break

if __name__ == '__main__':
    main()
